alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias g='git'
alias gs='git status -sb'
alias gd='git diff'
alias ga='git add'
alias gc='git commit -v'
alias gp='git push'
alias gco='git checkout'
alias gl='git log --oneline --graph --decorate -20'

alias path='echo -e ${PATH//:/\\n}'
alias reload='source ~/.bashrc'
