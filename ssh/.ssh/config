Host *
    AddKeysToAgent yes
    IdentitiesOnly yes
    HashKnownHosts yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

Host github.com github.com-daulpavid
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_daulpavid

Host github.com-somecompany
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_somecompany
